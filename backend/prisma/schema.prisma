generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model cliente {
  id_cliente       Int                @id @default(autoincrement())
  uuid             String             @unique @default(uuid())
  nome             String             @db.VarChar(100)
  tipo_cliente     tipo_cliente_enum?
  email            String?            @unique @db.VarChar(100)
  cidade           String?            @db.VarChar(50)
  uf               String?            @db.Char(2)
  numero           Int?
  cep              String?            @db.VarChar(10)
  bairro           String?            @db.VarChar(50)
  logradouro       String?            @db.VarChar(100)
  pessoafisica     pessoafisica?
  pessoajuridica   pessoajuridica?
  telefone_cliente telefone_cliente[]
  venda            venda[]
}

model compra {
  id_compra                   Int           @id @default(autoincrement())
  data_hora                   DateTime?     @db.Timestamp(6)
  valor_total                 Decimal?      @db.Decimal(10, 2)
  prazo_entrega               DateTime?     @db.Date
  fk_fornecedor_id_fornecedor Int?
  fornecedor                  fornecedor?   @relation(fields: [fk_fornecedor_id_fornecedor], references: [id_fornecedor], onDelete: Cascade, onUpdate: NoAction, map: "fk_compra_2")
  itenscompra                 itenscompra[]
  estoque                     estoque[]
}

model fornecedor {
  id_fornecedor       Int                   @id @default(autoincrement())
  uuid                String                @unique @default(uuid()) @db.Uuid
  cnpj                String                @unique @db.VarChar(14)
  razao_social        String                @db.VarChar(100)
  email               String?               @db.VarChar(50)
  politica_preco      Decimal               @db.Decimal(10, 2)
  prazo_entrega       Int?
  compra              compra[]
  telefone_fornecedor telefone_fornecedor[]
}

model funcionario {
  id_funcionario   Int      @id @default(autoincrement())
  nome             String   @db.VarChar(100)
  data_aniversario DateTime @db.Date
  venda            venda[]

  @@unique([nome, data_aniversario])
}

model itenscompra {
  fk_produto_id_produto Int
  fk_compra_id_compra   Int
  quantidade            Int?
  preco_compra          Decimal? @db.Decimal(10, 2)
  produto               produto  @relation(fields: [fk_produto_id_produto], references: [id_produto], onUpdate: NoAction, map: "fk_itenscompra_1")
  compra                compra   @relation(fields: [fk_compra_id_compra], references: [id_compra], onUpdate: NoAction, map: "fk_itenscompra_2")

  @@id([fk_produto_id_produto, fk_compra_id_compra])
}

model itensvenda {
  fk_produto_id_produto Int
  fk_venda_id_venda     Int
  preco_unitario        Decimal? @db.Decimal(10, 2)
  quantidade_vendida    Int?
  produto               produto  @relation(fields: [fk_produto_id_produto], references: [id_produto], onUpdate: NoAction, map: "fk_itensvenda_1")
  venda                 venda    @relation(fields: [fk_venda_id_venda], references: [id_venda], onUpdate: NoAction, map: "fk_itensvenda_2")

  @@id([fk_produto_id_produto, fk_venda_id_venda])
}

model pessoafisica {
  cpf                   String  @id @db.VarChar(11)
  fk_cliente_id_cliente Int     @unique
  cliente               cliente @relation(fields: [fk_cliente_id_cliente], references: [id_cliente], onDelete: Cascade, onUpdate: NoAction, map: "fk_pessoafisica_2")
}

model pessoajuridica {
  cnpj                  String  @id @db.VarChar(14)
  razao_social          String? @db.VarChar(100)
  nome_fantasia         String? @db.VarChar(50)
  fk_cliente_id_cliente Int     @unique
  cliente               cliente @relation(fields: [fk_cliente_id_cliente], references: [id_cliente], onDelete: Cascade, onUpdate: NoAction, map: "fk_pessoajuridica_2")
}

model categoria {
  id_categoria Int       @id @default(autoincrement())
  nome         String    @unique @db.VarChar(50)
  produto      produto[]
}

model marca {
  id_marca Int      @id @default(autoincrement())
  nome     String   @unique
  modelos  modelo[]
}

model modelo {
  id_modelo  Int       @id @default(autoincrement())
  nome       String
  fk_marca_id Int
  marca      marca     @relation(fields: [fk_marca_id], references: [id_marca])
  produtos   produto[]

  @@unique([nome, fk_marca_id])
}

model produto {
  id_produto     Int     @id @default(autoincrement())
  codigo_produto String  @unique @db.VarChar(25)
  nome           String? @db.VarChar(50)
  descricao      String  @db.VarChar(100)

  fk_categoria_id Int
  fk_modelo_id    Int?
  categoria       categoria @relation(fields: [fk_categoria_id], references: [id_categoria], onUpdate: NoAction)
  modelo          modelo?   @relation(fields: [fk_modelo_id], references: [id_modelo], onUpdate: NoAction)

  preco_compra Decimal? @db.Decimal(10, 2)
  preco_custo  Decimal? @db.Decimal(10, 2)
  preco_venda  Decimal  @db.Decimal(10, 2)
  margem_lucro Decimal? @db.Decimal(10, 2)

  itenscompra itenscompra[]
  itensvenda  itensvenda[]
  estoque     estoque[]
}

model estoque {
  id_estoque     Int                 @id @default(autoincrement())
  tipo_movimento tipo_movimento_enum
  quantidade     Int
  estoque_atual  Int
  estoque_minimo Int?
  estoque_ideal  Int?
  data_hora      DateTime            @default(now()) @db.Timestamp(6)
  observacao     String?             @db.VarChar(200)

  fk_produto_id Int
  produto       produto @relation(fields: [fk_produto_id], references: [id_produto], onDelete: Cascade, onUpdate: NoAction)

  fk_venda_id Int?
  venda       venda?  @relation(fields: [fk_venda_id], references: [id_venda], onDelete: SetNull, onUpdate: NoAction)

  fk_compra_id Int?
  compra       compra? @relation(fields: [fk_compra_id], references: [id_compra], onDelete: SetNull, onUpdate: NoAction)
}

model telefone_cliente {
  telefone_cliente    String  @unique @db.VarChar(14)
  telefone_cliente_pk Int
  cliente             cliente @relation(fields: [telefone_cliente_pk], references: [id_cliente], onDelete: Cascade, onUpdate: NoAction, map: "fk_telefone_cliente_2")

  @@id([telefone_cliente_pk, telefone_cliente])
}

model telefone_fornecedor {
  telefone_fornecedor     String     @unique @db.VarChar(14)
  telefone_forncecedor_pk Int
  fornecedor              fornecedor @relation(fields: [telefone_forncecedor_pk], references: [id_fornecedor], onDelete: Cascade, onUpdate: NoAction, map: "fk_telefone_forncecedor_2")

  @@id([telefone_forncecedor_pk, telefone_fornecedor])
}

model venda {
  id_venda                      Int                   @id @default(autoincrement())
  valor_total                   Decimal?              @db.Decimal(10, 2)
  status_pagamento              status_pagamento_enum
  status_venda                  status_venda_enum     @default(ATIVA)
  data_vencimento               DateTime?             @db.Date
  data_hora                     DateTime              @db.Timestamp(6)
  fk_cliente_id_cliente         Int?
  fk_funcionario_id_funcionario Int
  itensvenda                    itensvenda[]
  estoque                       estoque[]
  cliente                       cliente?              @relation(fields: [fk_cliente_id_cliente], references: [id_cliente], onDelete: SetNull, onUpdate: NoAction, map: "fk_venda_2")
  funcionario                   funcionario           @relation(fields: [fk_funcionario_id_funcionario], references: [id_funcionario], onDelete: Cascade, onUpdate: NoAction, map: "fk_venda_3")
}

enum status_pagamento_enum {
  PAGO
  EM_ABERTO
}

enum status_venda_enum {
  ATIVA
  EFETUADA
  CANCELADA
}

enum tipo_cliente_enum {
  FISICO
  JURIDICO
}

enum tipo_movimento_enum {
  ENTRADA
  SAIDA
  AJUSTE
}
